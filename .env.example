# LifeDex environment — ALL optional for local mock mode.
# Copy to .env and fill in only what you need. With AI_PROVIDER=mock and
# MAPS_PROVIDER=mock the app runs fully offline with NO API keys.

# Supabase (leave blank to run without a backend in mock mode)
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Provider selection: "mock" (default, no keys) or a real provider id later.
AI_PROVIDER=mock
MAPS_PROVIDER=mock
